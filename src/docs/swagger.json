{
    "swagger": "2.0",
    "info": {
        "description": "Feature flag management API",
        "title": "Flagpole API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:4000",
    "basePath": "/api/v1",
    "paths": {
        "/flag": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "flags"
                ],
                "summary": "Create a feature flag",
                "parameters": [
                    {
                        "description": "Flag definition",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.flagPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "400": {
                        "description": "bad request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/flag/{flagname}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "flags"
                ],
                "summary": "Get a feature flag",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Flag name",
                        "name": "flagname",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handlers.flagResponse"
                        }
                    },
                    "400": {
                        "description": "missing flagname",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "flag not found",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "put": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "flags"
                ],
                "summary": "Update a feature flag's value",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Flag name",
                        "name": "flagname",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "New value",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.flagPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "400": {
                        "description": "bad request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/flags/evaluate": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "flags"
                ],
                "summary": "Evaluate feature flags for a context",
                "parameters": [
                    {
                        "description": "Evaluation request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.evaluateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handlers.evaluateResponse"
                        }
                    },
                    "400": {
                        "description": "bad request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/login": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Authentication"
                ],
                "summary": "Login and receive a JWT",
                "parameters": [
                    {
                        "description": "Credentials",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.authPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "bad request",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "invalid credentials",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/signup": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "Authentication"
                ],
                "summary": "Register a new user",
                "parameters": [
                    {
                        "description": "Credentials",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.authPayload"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created"
                    },
                    "400": {
                        "description": "bad request",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "409": {
                        "description": "email already in use",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handlers.authPayload": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "handlers.evaluateRequest": {
            "type": "object",
            "properties": {
                "context": {
                    "$ref": "#/definitions/handlers.evaluationContext"
                },
                "flags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "handlers.evaluateResponse": {
            "type": "object",
            "properties": {
                "context": {
                    "$ref": "#/definitions/handlers.evaluationContext"
                },
                "flags": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/definitions/models.FlagValue"
                    }
                }
            }
        },
        "handlers.evaluationContext": {
            "type": "object",
            "properties": {
                "attributes": {
                    "type": "object",
                    "additionalProperties": true
                },
                "key": {
                    "type": "string"
                }
            }
        },
        "handlers.flagPayload": {
            "type": "object",
            "properties": {
                "flagName": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                },
                "value": {}
            }
        },
        "handlers.flagResponse": {
            "type": "object",
            "properties": {
                "flagName": {
                    "type": "string"
                },
                "type": {
                    "$ref": "#/definitions/models.FlagType"
                },
                "value": {}
            }
        },
        "models.FlagType": {
            "type": "string",
            "enum": [
                "bool",
                "string",
                "number"
            ],
            "x-enum-varnames": [
                "FlagTypeBool",
                "FlagTypeString",
                "FlagTypeNumber"
            ]
        },
        "models.FlagValue": {
            "type": "object",
            "properties": {
                "type": {
                    "$ref": "#/definitions/models.FlagType"
                },
                "value": {}
            }
        }
    }
}